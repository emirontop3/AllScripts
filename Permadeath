if _G.Perma == true then
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")

    local player = Players.LocalPlayer
    local activeConnection = nil

    local function startPermaDeath(character)
        local root = character:WaitForChild("HumanoidRootPart")
        local humanoid = character:WaitForChild("Humanoid")
        
        if activeConnection then activeConnection:Disconnect() end

        -- 1. DURUMLARI DÜZENLE
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        -- FallingDown ve Ragdoll'u kapatmak yürüme bozukluklarını engeller
        humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        
        -- Yürüme sorunu çözümü: RootPart'ın çarpışmasını açık tutuyoruz 
        -- ama diğer parçaların (kol, bacak) bir yere takılmasını engellemek için sadece iç içe geçmeyi kapatıyoruz.
        for _, part in pairs(character:GetChildren()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.CanCollide = false
            end
        end
        root.CanCollide = true -- Yürüyebilmek için zemine basması şart!

        -- 2. STABİL FİZİK DÖNGÜSÜ
        activeConnection = RunService.Heartbeat:Connect(function()
            if not root or not root.Parent or humanoid.Health == 0 then
                -- Karakterin fiziksel olarak aktif kalmasını sağlar ama yürüme hızını ellemez
                -- Velocity'e dokunmuyoruz, sadece düşmeyi/silinmeyi engelleyen küçük bir itki.
                local vel = root.AssemblyLinearVelocity
                root.AssemblyLinearVelocity = Vector3.new(vel.X, vel.Y, vel.Z)
            end
        end)
    end

    -- 3. YENİDEN DOĞMA BAĞLANTISI
    player.CharacterAdded:Connect(function(newChar)
        task.wait(1)
        startPermaDeath(newChar)
    end)

    if player.Character then
        task.spawn(function() startPermaDeath(player.Character) end)
    end

    print("--- PERMA DEATH: YÜRÜME DÜZELTİLDİ ---")
end
