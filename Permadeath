if _G.Perma == true then
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")

    local player = Players.LocalPlayer
    local activeConnection = nil

    local function startPermaDeath(character)
        local root = character:WaitForChild("HumanoidRootPart")
        local humanoid = character:WaitForChild("Humanoid")
        
        -- Eski bağlantıyı temizle
        if activeConnection then activeConnection:Disconnect() end

        -- 1. DURUMLARI AYARLA
        -- Karakterin ölmesini ve yere yığılmasını engeller
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        
        -- 2. CANCOLLIDE AYARI (FULL AÇIK)
        -- Karakterin tüm parçalarının çarpışmasını aktif eder
        for _, part in pairs(character:GetChildren()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end

        -- 3. DOĞAL FİZİK DÖNGÜSÜ
        activeConnection = RunService.Heartbeat:Connect(function()
            if not root or not root.Parent then
                if activeConnection then activeConnection:Disconnect() end
                return
            end

            -- Hıza (Velocity) müdahale etmiyoruz, karakter tamamen özgür.
            -- Sadece karakterin ağ sahipliğini (network ownership) canlı tutmak için 
            -- arka planda fizik motoruyla olan bağı koruyoruz.
            if humanoid.Health <= 0 then
                -- Karakterin ölmesine rağmen parçaların kaybolmaması için gereken stabilite:
                local currentVel = root.AssemblyLinearVelocity
                root.AssemblyLinearVelocity = currentVel + Vector3.new(0, 0.0001, 0)
            end
        end)
    end

    -- 4. OTOMATİK BAĞLANTI
    player.CharacterAdded:Connect(function(newChar)
        task.wait(1)
        startPermaDeath(newChar)
    end)

    if player.Character then
        task.spawn(function() startPermaDeath(player.Character) end)
    end

    print("--- PERMA DEATH: FULL COLLISION & NORMAL HIZ AKTİF ---")
end
